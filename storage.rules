rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /Player Musicale/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == "torrespost@gmail.com" ||
        request.auth.token.email_verified == true
      );
    }
    match /articles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        request.auth.token.email == "torrespost@gmail.com" ||
        request.auth.token.email_verified == true
      );
    }
  }
}
